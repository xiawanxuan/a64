# ============================================================
# 风电场设备诊断平台 - 环境变量示例配置
# 复制此文件为 .env 并根据实际部署环境修改
# ============================================================

# -------------------- 应用基础配置 --------------------
APP_NAME=WindFarm-Diagnosis-Platform
APP_VERSION=1.0.0
API_PREFIX=/api/v1
DEBUG=true
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# -------------------- 目录配置 --------------------
LOG_DIR=./logs
CHUNK_UPLOAD_DIR=./data/chunk_uploads
FAILED_ANALYSIS_DIR=./data/failed_analysis
HYPER_PARAMS_CONFIG=./config/hyperparams.yaml

# -------------------- 性能参数 --------------------
BATCH_INSERT_SIZE=10000
MAX_CHUNK_SIZE_MB=100

# -------------------- TimescaleDB (PostgreSQL 时序库) --------------------
TIMESCALEDB_HOST=127.0.0.1
TIMESCALEDB_PORT=5432
TIMESCALEDB_USER=postgres
TIMESCALEDB_PASSWORD=postgres
TIMESCALEDB_DATABASE=windfarm_ts
TIMESCALEDB_POOL_SIZE=20
TIMESCALEDB_MAX_OVERFLOW=30
TIMESCALEDB_POOL_RECYCLE=3600

# -------------------- MySQL (台账库) --------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=windfarm_ledger
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20
MYSQL_POOL_RECYCLE=3600
MYSQL_CHARSET=utf8mb4

# -------------------- 故障回调推送 --------------------
FAULT_CALLBACK_ENABLED=false
FAULT_CALLBACK_URL=https://ops.example.com/api/fault-alarm
FAULT_CALLBACK_TIMEOUT_SEC=10
FAULT_CALLBACK_MAX_RETRIES=3
FAULT_CALLBACK_RETRY_INTERVAL_SEC=2
FAULT_CALLBACK_AUTH_HEADER=X-Api-Key
FAULT_CALLBACK_AUTH_TOKEN=your-api-key-here
